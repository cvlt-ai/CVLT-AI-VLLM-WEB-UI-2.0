# CVLT AI vLLM Gradio WebUI 2.0 - Environment Configuration
# Copy this file to .env and customize for your environment

# ==============================================================================
# MODEL CONFIGURATION
# ==============================================================================

# Default model to load on startup
MODEL_NAME=meta-llama/Llama-2-7b-chat-hf

# Path to local model directory (optional, override MODEL_NAME)
MODEL_PATH=

# ==============================================================================
# vLLM CONFIGURATION
# ==============================================================================

# Tensor parallel size for multi-GPU setups
TENSOR_PARALLEL_SIZE=1

# Pipeline parallel size for multi-GPU setups
PIPELINE_PARALLEL_SIZE=1

# GPU memory utilization (0.0 to 1.0)
GPU_MEMORY_UTILIZATION=0.9

# Maximum context length
MAX_MODEL_LEN=4096

# Swap space size (GiB) for paging attention
SWAP_SPACE=4

# Enable/disable continuous batching
ENABLE_CHUNKED_PREFILL=true

# ==============================================================================
# SERVER CONFIGURATION
# ==============================================================================

# Host to bind to
HOST=0.0.0.0

# Port to bind to
PORT=7860

# Enable/disable share link
SHARE=false

# ==============================================================================
# RAG CONFIGURATION
# ==============================================================================

# ChromaDB configuration
CHROMA_DB_PATH=./data/chroma
CHROMA_TENANT=chroma_default_tenant
CHROMA_DATABASE=chroma_default_database

# Embedding model for RAG
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Chunk size for document processing
CHUNK_SIZE=1000

# Chunk overlap
CHUNK_OVERLAP=200

# ==============================================================================
# API KEYS (Optional)
# ==============================================================================

# Hugging Face token for accessing gated models
HUGGING_FACE_HUB_TOKEN=

# Google API key for web search (optional)
GOOGLE_API_KEY=

# Google Custom Search Engine ID (optional)
GOOGLE_CSE_ID=

# ==============================================================================
# LOGGING
# ==============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ==============================================================================
# ADVANCED OPTIONS
# ==============================================================================

# Enable/disable quantization
QUANTIZATION=none  # Options: none, awq, gptq, fp8

# Trust remote code (for some custom models)
TRUST_REMOTE_CODE=false

# Download dir for models
DOWNLOAD_DIR=.

# Cache dir for vLLM
VLLM_CACHE_DIR=./cache
